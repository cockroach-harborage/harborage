{
	"name": "@harborage/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler dev --port 8788",
		"typecheck": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@harborage/crypto": "workspace:*",
		"@harborage/foundry": "workspace:*",
		"@harborage/outbox": "workspace:*",
		"@harborage/worker-lib": "workspace:*",
		"idb": "^8.0.3"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.20.0",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-cloudflare": "^7.2.0",
		"@sveltejs/kit": "^2.69.0",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"svelte": "^5.56.0",
		"svelte-check": "^4.7.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.10",
		"wrangler": "^4.114.0"
	}
}
